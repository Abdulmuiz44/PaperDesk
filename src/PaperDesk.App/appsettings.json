{
  "PaperDesk": {
    "Database": {
      "FilePath": "%LocalAppData%/PaperDesk/paperdesk.db"
    },
    "Watcher": {
      "DefaultFolders": [
        "%UserProfile%/Downloads",
        "%UserProfile%/Desktop"
      ]
    },
    "Ocr": {
      "DefaultLanguage": "en-US"
    },
    "Logging": {
      "MinimumLevel": "Information"
    }
  }
}
