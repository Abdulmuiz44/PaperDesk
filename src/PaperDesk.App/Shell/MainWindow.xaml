<Window x:Class="PaperDesk.App.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PaperDesk"
        Width="1200"
        Height="760"
        MinWidth="960"
        MinHeight="600"
        Background="{DynamicResource SurfaceBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="PaperDesk"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Local document workflow"
                               Foreground="#CCFFFFFF"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         Background="Transparent"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="14"
                         SelectedIndex="0"
                         Margin="0,8,0,0" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="White" Padding="16" CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Scaffold Status"
                               FontWeight="SemiBold"
                               FontSize="16" />
                    <Border Margin="12,0,0,0"
                            Background="#FFEFF6FF"
                            CornerRadius="10"
                            Padding="8,3">
                        <TextBlock Text="{Binding PhaseStatus}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" />
                    </Border>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="1" Margin="0,16,0,0">
                <TabItem Header="Dashboard">
                    <StackPanel Margin="16">
                        <TextBlock Text="Phase 1 Foundation" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0" Text="Folder watching, queueing, metadata extraction, activity logging, and safe preview generation are wired in services." TextWrapping="Wrap" />
                    </StackPanel>
                </TabItem>
                <TabItem Header="Watched Folders">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Watch Configuration" FontSize="18" FontWeight="SemiBold" />

                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Margin="0,0,8,0"
                                     Padding="8,6"
                                     Text="{Binding WatchedFolderInput, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="0,0,8,0"
                                    Padding="12,6"
                                    Click="BrowseFolderClick"
                                    Content="Browse" />
                            <Button Grid.Column="2"
                                    Padding="12,6"
                                    Click="AddFolderClick"
                                    Content="Add" />
                        </Grid>

                        <ListView Grid.Row="2"
                                  Margin="0,12,0,0"
                                  ItemsSource="{Binding WatchedFolders}"
                                  SelectedItem="{Binding SelectedWatchedFolder, Mode=TwoWay}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="470" Header="Folder">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="110" Header="Recursive">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding IsRecursive}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="90" Header="Enabled">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding IsEnabled}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="3" Margin="0,12,0,0" Orientation="Horizontal">
                            <Button Padding="12,6" Margin="0,0,8,0" Click="RemoveFolderClick" Content="Remove Selected" />
                            <Button Padding="12,6" Margin="0,0,8,0" Click="StartWatchingClick" Content="Start Watching" />
                            <Button Padding="12,6" Click="StopWatchingClick" Content="Stop Watching" />
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Review Queue">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Review rename and routing suggestions" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,0"
                                   Text="{Binding ReviewSuggestions.Count, StringFormat=Pending suggestions: {0}}"
                                   Foreground="#FF4B5563" />
                        <ListView Grid.Row="2"
                                  Margin="0,12,0,0"
                                  ItemsSource="{Binding ReviewSuggestions}"
                                  SelectedItem="{Binding SelectedReviewSuggestion, Mode=TwoWay}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="220" Header="Proposed Name">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ProposedFileName, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="380" Header="Destination">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ProposedDestinationDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="110" Header="Confidence" DisplayMemberBinding="{Binding Confidence}" />
                                    <GridViewColumn Width="240" Header="Reason" DisplayMemberBinding="{Binding Reason}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <StackPanel Grid.Row="3" Margin="0,12,0,0" Orientation="Horizontal">
                            <Button Padding="12,6" Margin="0,0,8,0" Click="RefreshReviewQueueClick" Content="Refresh" />
                            <Button Padding="12,6" Margin="0,0,8,0" Click="ApproveSelectedClick" Content="Approve + Apply" />
                            <Button Padding="12,6" Click="SkipSelectedClick" Content="Skip" />
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Search">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Margin="0,0,8,0"
                                     Padding="8,6"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Padding="12,6"
                                    Click="SearchClick"
                                    Content="Search" />
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      Margin="0,0,8,0"
                                      ItemsSource="{Binding SearchDocumentTypes}"
                                      SelectedItem="{Binding SelectedSearchDocumentType, Mode=TwoWay}" />
                            <ComboBox Grid.Column="1"
                                      Margin="0,0,8,0"
                                      ItemsSource="{Binding SearchStatuses}"
                                      SelectedItem="{Binding SelectedSearchStatus, Mode=TwoWay}" />
                            <TextBox Grid.Column="2"
                                     Padding="8,6"
                                     Text="{Binding SearchSourceFolder, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Optional source folder path prefix" />
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Margin="0,0,8,0"
                                     Padding="8,6"
                                     Text="{Binding SearchFromDate, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="From date (e.g. 2026-04-01)" />
                            <TextBox Grid.Column="1"
                                     Padding="8,6"
                                     Text="{Binding SearchToDate, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="To date (e.g. 2026-04-30)" />
                        </Grid>

                        <ListView Grid.Row="3"
                                  Margin="0,12,0,0"
                                  ItemsSource="{Binding SearchResults}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="280" Header="Path" DisplayMemberBinding="{Binding OriginalPath}" />
                                    <GridViewColumn Width="120" Header="Type" DisplayMemberBinding="{Binding DocumentType}" />
                                    <GridViewColumn Width="120" Header="Confidence" DisplayMemberBinding="{Binding OcrConfidence}" />
                                    <GridViewColumn Width="170" Header="Processed">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProcessedUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="260" Header="Preview" DisplayMemberBinding="{Binding Preview}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="Duplicates">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Padding="12,6" Margin="0,0,8,0" Click="RefreshDuplicatesClick" Content="Scan Duplicates" />
                            <Button Padding="12,6" Margin="0,0,8,0" Click="MarkCanonicalClick" Content="Set Canonical" />
                            <Button Padding="12,6" Click="MoveDuplicatesClick" Content="Move Non-Canonical to Review Folder" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Text="{Binding DuplicateGroups.Count, StringFormat=Groups found: {0}}"
                                   Foreground="#FF4B5563" />
                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ListView Grid.Column="0"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding DuplicateGroups}"
                                      SelectedItem="{Binding SelectedDuplicateGroup, Mode=TwoWay}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="80" Header="Type" DisplayMemberBinding="{Binding MatchType}" />
                                        <GridViewColumn Width="60" Header="Count" DisplayMemberBinding="{Binding Count}" />
                                        <GridViewColumn Width="240" Header="Reason" DisplayMemberBinding="{Binding Reason}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <ListView Grid.Column="1"
                                      ItemsSource="{Binding DuplicateDocuments}"
                                      SelectedItem="{Binding SelectedDuplicateDocument, Mode=TwoWay}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="180" Header="File" DisplayMemberBinding="{Binding FileName}" />
                                        <GridViewColumn Width="280" Header="Path" DisplayMemberBinding="{Binding Path}" />
                                        <GridViewColumn Width="90" Header="Type" DisplayMemberBinding="{Binding DocumentType}" />
                                        <GridViewColumn Width="90" Header="Status" DisplayMemberBinding="{Binding Status}" />
                                        <GridViewColumn Width="220" Header="Hash" DisplayMemberBinding="{Binding Sha256Hash}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Activity Log">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Live processing events" FontSize="18" FontWeight="SemiBold" />
                        <ListView Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding ActivityEvents}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="170" Header="Time">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding OccurredUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="140" Header="Type" DisplayMemberBinding="{Binding ActivityType}" />
                                    <GridViewColumn Width="330" Header="Message" DisplayMemberBinding="{Binding Message}" />
                                    <GridViewColumn Width="220" Header="Path" DisplayMemberBinding="{Binding Path}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="Settings">
                    <StackPanel Margin="16">
                        <TextBlock Text="Runtime status" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Margin="0,10,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
