<Window x:Class="PaperDesk.App.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:PaperDesk.App.Shell"
        mc:Ignorable="d"
        Title="PaperDesk"
        Width="1200"
        Height="760"
        MinWidth="960"
        MinHeight="600"
        Background="{DynamicResource SurfaceBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="PaperDesk"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Local document workflow"
                               Foreground="#CCFFFFFF"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         Background="Transparent"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="14"
                         SelectedIndex="0"
                         Margin="0,8,0,0" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="White" Padding="16" CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Scaffold Status"
                               FontWeight="SemiBold"
                               FontSize="16" />
                    <Border Margin="12,0,0,0"
                            Background="#FFEFF6FF"
                            CornerRadius="10"
                            Padding="8,3">
                        <TextBlock Text="Foundation Ready"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" />
                    </Border>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="1" Margin="0,16,0,0">
                <TabItem Header="Dashboard">
                    <TextBlock Margin="16" Text="Dashboard placeholder content (non-functional)." />
                </TabItem>
                <TabItem Header="Watched Folders">
                    <TextBlock Margin="16" Text="Watched Folders placeholder content (non-functional)." />
                </TabItem>
                <TabItem Header="Review Queue">
                    <TextBlock Margin="16" Text="Review Queue placeholder content (non-functional)." />
                </TabItem>
                <TabItem Header="Search">
                    <TextBlock Margin="16" Text="Search placeholder content (non-functional)." />
                </TabItem>
                <TabItem Header="Duplicates">
                    <TextBlock Margin="16" Text="Duplicates placeholder content (non-functional)." />
                </TabItem>
                <TabItem Header="Activity Log">
                    <TextBlock Margin="16" Text="Activity Log placeholder content (non-functional)." />
                </TabItem>
                <TabItem Header="Settings">
                    <TextBlock Margin="16" Text="Settings placeholder content (non-functional)." />
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
